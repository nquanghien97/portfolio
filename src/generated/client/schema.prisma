generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Project {
  id            Int      @id @default(autoincrement())
  slug          String   @unique
  titleEn       String
  titleVi       String
  descriptionEn String
  descriptionVi String
  thumbnailUrl  String   @default("")
  liveUrl       String   @default("")
  githubUrl     String   @default("")
  tags          String   @default("")
  featured      Boolean  @default(false)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BlogPost {
  id           Int      @id @default(autoincrement())
  slug         String   @unique
  titleEn      String
  titleVi      String
  excerptEn    String   @default("")
  excerptVi    String   @default("")
  contentEn    String   @default("")
  contentVi    String   @default("")
  thumbnailUrl String   @default("")
  category     String   @default("general")
  tags         String   @default("")
  published    Boolean  @default(false)
  readingTime  Int      @default(5)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
